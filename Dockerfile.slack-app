FROM python:3.11-slim

WORKDIR /app

# Copy requirements and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source code
COPY src/ ./src/

# Set Python path to /app so we can import src
ENV PYTHONPATH=/app

# Start the slack app
CMD ["python", "-m", "src.slack_app"]
