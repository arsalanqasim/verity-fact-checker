{
    "display_information": {
        "name": "Verity",
        "description": "Real-time AI fact-checking assistant powered by Gemini & Brave Search MCP.",
        "background_color": "#1A1B2F"
    },
    "features": {
        "app_home": {
            "home_tab_enabled": true
        },
        "bot_user": {
            "display_name": "Verity",
            "always_online": true
        }
    },
    "functions": {
        "verify_claim": {
            "title": "Verify a Claim",
            "description": "Fact-checks a claim or link and returns a sourced verdict.",
            "input_parameters": {
                "claim_or_link": {
                    "type": "string",
                    "title": "Claim or link",
                    "description": "The claim text, YouTube link, or article link to fact-check.",
                    "is_required": true
                }
            },
            "output_parameters": {
                "verdict": {
                    "type": "string",
                    "title": "Verdict",
                    "is_required": true
                },
                "confidence": {
                    "type": "string",
                    "title": "Confidence",
                    "is_required": true
                },
                "summary": {
                    "type": "string",
                    "title": "Summary",
                    "is_required": true
                },
                "canvas_url": {
                    "type": "string",
                    "title": "Canvas report URL",
                    "is_required": false
                }
            }
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "app_mentions:read",
                "chat:write",
                "chat:write.public",
                "assistant:write",
                "channels:history",
                "groups:history",
                "canvases:write",
                "lists:write",
                "channels:join"
            ]
        }
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_home_opened",
                "app_mention",
                "message.channels",
                "message.groups"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false
    }
}
