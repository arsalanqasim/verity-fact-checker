# Verity — Environment Variables Configuration Template
# Copy this file to .env and fill in real values.
# Never commit .env to version control — it is gitignored.

# ==========================================
# REQUIRED CONFIGURATION
# ==========================================

# Slack Bot User OAuth Token (starts with xoxb-).
# Obtained from: Slack App Dashboard -> OAuth & Permissions.
SLACK_BOT_TOKEN=

# Slack App Signing Secret.
# Obtained from: Slack App Dashboard -> Basic Information -> App Credentials.
SLACK_SIGNING_SECRET=

# Slack App-level Token for Socket Mode (starts with xapp-).
# Must include the `connections:write` scope.
# Obtained from: Slack App Dashboard -> Basic Information -> App-Level Tokens.
SLACK_APP_TOKEN=

# Google AI Studio API key (https://aistudio.google.com/apikey) used for Gemini models.
GEMINI_API_KEY=

# Brave Search MCP server SSE endpoint URL (e.g. http://localhost:3001/sse for local dev).
# Used to query external search results.
BRAVE_SEARCH_MCP_URL=http://localhost:3001/sse


# ==========================================
# OPTIONAL CONFIGURATION
# ==========================================

# Optional: Slack User OAuth Token (starts with xoxp-) for Workspace Memory (Real-Time Search API).
# Used to check if a claim has already been discussed in the workspace.
# Requires the following granular search user scopes:
# - search:read.public (essential)
# - search:read.private (optional)
# - search:read.mpim (optional)
# - search:read.im (optional)
SLACK_USER_TOKEN=

# Optional: The Slack List ID used to log fact-checked claims.
# If empty or not set, Slack List logging is skipped.
SLACK_LIST_ID=

# Optional: The Column ID in the Slack List mapping to the "Claim" field.
SLACK_LIST_COL_CLAIM=

# Optional: The Column ID in the Slack List mapping to the "Verdict" field.
SLACK_LIST_COL_VERDICT=

# Optional: The Column ID in the Slack List mapping to the "Confidence" field.
SLACK_LIST_COL_CONFIDENCE=

# Optional: The Column ID in the Slack List mapping to the "Summary" field.
SLACK_LIST_COL_SUMMARY=
