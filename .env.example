# Verity — required environment variables
# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# Slack app credentials (from api.slack.com → Your App → OAuth & Permissions)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Slack app-level token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=

# Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Brave Search MCP server endpoint (e.g. http://localhost:3001 for local dev)
BRAVE_SEARCH_MCP_URL=

# Optional: Slack User Token (starts with xoxp-) for Workspace Memory (Real-Time Search API)
# Requires granular RTS scopes instead of legacy search:read:
# - search:read.public (essential)
# - search:read.private (optional)
# - search:read.mpim (optional)
# - search:read.im (optional)
# - search:read.files (optional)
# - search:read.users (optional)
SLACK_USER_TOKEN=

